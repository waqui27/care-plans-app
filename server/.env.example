# copy this file to server/.env and fill in your own values — never commit .env
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/care-plans

# use a long random string in production, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret

# your super admin sign-in — choose your own, do not reuse a demo value
SEED_SUPERADMIN_EMAIL=superadmin@example.com
SEED_SUPERADMIN_PASSWORD=replace-with-a-strong-password

# seed demo data (plans, a sample page, leads, analytics) on first boot
SEED_DEMO=true
